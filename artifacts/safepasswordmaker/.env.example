# ─── CMS Mode ────────────────────────────────────────────────────────────────
# "local"  = use the built-in Node/Express API (default for development)
# "drupal" = use Headless Drupal JSON:API on your cPanel hosting
VITE_CMS_MODE=local

# ─── Local API (used when VITE_CMS_MODE=local) ───────────────────────────────
# Leave blank to use the built-in Vite proxy (/api-server/api)
VITE_API_URL=

# ─── Drupal (used when VITE_CMS_MODE=drupal) ─────────────────────────────────
# URL of your Drupal installation on cPanel (no trailing slash)
VITE_DRUPAL_URL=https://cms.yourdomain.com

# OAuth 2.0 client credentials (from Drupal admin > Services > Consumers)
VITE_DRUPAL_CLIENT_ID=safepassmaker
VITE_DRUPAL_CLIENT_SECRET=your_client_secret_here

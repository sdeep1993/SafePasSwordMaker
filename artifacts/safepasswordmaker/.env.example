# SafePassWordmaker — Environment Variables
# Copy this file to .env and fill in your Drupal details.

# ─── Drupal Headless CMS ─────────────────────────────────────────────────────
# URL of your Drupal installation (no trailing slash)
# Local:  http://localhost/safepassmaker-cms/web
# cPanel: https://cms.yourdomain.com
VITE_DRUPAL_URL=https://cms.yourdomain.com

# OAuth 2.0 credentials from Drupal admin → Configuration → Consumers
# These match the pre-configured values in drush-setup.sh
VITE_DRUPAL_CLIENT_ID=safepassmaker
VITE_DRUPAL_CLIENT_SECRET=Spm@Secret2024!
